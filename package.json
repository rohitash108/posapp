{
  "name": "cspos-mobile",
  "version": "1.0.10",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "node scripts/write-version.js && npx expo export -p web",
    "make:ico": "node scripts/make-ico.js",
    "write-version": "node scripts/write-version.js",
    "electron:dev": "npm run build:web && electron electron/main.js",
    "electron:build:portable": "npm run make:ico && npm run build:web && electron-builder --win portable --x64",
    "electron:build:installer": "npm run make:ico && npm run build:web && electron-builder --win nsis --x64",
    "electron:build:win": "npm run make:ico && npm run build:web && electron-builder --win --x64",
    "electron:publish:win": "npm run make:ico && npm run build:web && electron-builder --win nsis portable --x64 --publish always"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-linking": "^56.0.14",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "express": "^4.18.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.2.1",
    "react-native-uuid": "^2.0.2",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.3.3"
  },
  "build": {
    "appId": "com.gtc.pos",
    "productName": "GTC POS",
    "copyright": "© 2025 Global Tea Cafe",
    "directories": {
      "app": "electron",
      "output": "electron-dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "rohitash108",
        "repo": "posapp",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "assets/global-tea-cafe-logo.png",
        "to": "assets/global-tea-cafe-logo.png"
      },
      {
        "from": "assets/icon.ico",
        "to": "assets/icon.ico"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Global Tea Cafe",
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "GTC-POS-Portable-${version}.exe",
      "requestExecutionLevel": "user",
      "useZip": false
    },
    "nsis": {
      "artifactName": "GTC-POS-Setup-${version}.exe",
      "oneClick": false,
      "differentialPackage": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GTC POS",
      "menuCategory": "Global Tea Cafe",
      "uninstallDisplayName": "GTC POS — Global Tea Cafe",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "license": false
    }
  }
}
